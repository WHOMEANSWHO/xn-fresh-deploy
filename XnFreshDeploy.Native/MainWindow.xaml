<Window x:Class="XnFreshDeploy.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:XnFreshDeploy"
        Title="Xn Fresh Deploy" Width="1160" Height="820" MinWidth="1000" MinHeight="680"
        WindowStartupLocation="CenterScreen" Background="{StaticResource BackgroundBrush}"
        FontFamily="Segoe UI" TextOptions.TextFormattingMode="Display"
        Icon="pack://application:,,,/app.ico"
        PreviewKeyDown="Window_PreviewKeyDown">
  <Grid Margin="24,20">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Header -->
    <Grid Grid.Row="0" Margin="0,0,0,18">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <StackPanel VerticalAlignment="Center">
        <TextBlock Text="Xn Fresh Deploy" FontSize="20" FontWeight="SemiBold"/>
        <TextBlock Text="FiveM profiles, packs, and PC setup" Style="{StaticResource Hint}" Margin="0,2,0,0"/>
      </StackPanel>
      <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
        <Border x:Name="FiveMBadge" Style="{StaticResource StatusChip}" Margin="0,0,8,0">
          <TextBlock x:Name="FiveMStatusText" Text="FiveM …" FontSize="11.5"/>
        </Border>
        <Border Style="{StaticResource StatusChip}" Margin="0,0,10,0">
          <TextBlock Text="Canary channel" FontSize="11.5"/>
        </Border>
        <Button x:Name="HelpButton" Content="Help" Style="{StaticResource TextButton}" Margin="0,0,8,0" Click="Help_Click"/>
        <TextBlock x:Name="VersionText" Text="4.1.1" Foreground="{StaticResource MutedBrush}" FontSize="11" VerticalAlignment="Center" Cursor="Hand" MouseLeftButtonUp="Version_Click" ToolTip="About"/>
      </StackPanel>
    </Grid>

    <Border x:Name="UpdateBanner" Grid.Row="0" Margin="0,78,0,0" Background="{StaticResource AccentSoftBrush}" BorderBrush="#5A4034" BorderThickness="1" CornerRadius="10" Padding="12,10" Visibility="Collapsed">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <StackPanel>
          <TextBlock x:Name="UpdateBannerTitle" Text="Update available" FontWeight="SemiBold"/>
          <TextBlock x:Name="UpdateBannerDetail" Style="{StaticResource Hint}" Margin="0,2,0,0"/>
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal">
          <Button Content="Download" Style="{StaticResource PrimaryButton}" Padding="12,7" Click="DownloadUpdate_Click"/>
          <Button Content="Later" Style="{StaticResource TextButton}" Margin="8,0,0,0" Click="DismissUpdate_Click"/>
        </StackPanel>
      </Grid>
    </Border>

    <!-- Nav -->
    <Border Grid.Row="0" Margin="0,52,0,0" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource EdgeBrush}" BorderThickness="1" CornerRadius="10" Padding="4" HorizontalAlignment="Left">
      <StackPanel Orientation="Horizontal">
        <Button x:Name="ProfilesNavButton" Content="Profiles" Style="{StaticResource NavButton}" MinWidth="108" Click="ProfilesNav_Click"/>
        <Button x:Name="LibraryNavButton" Content="Library" Style="{StaticResource NavButton}" MinWidth="108" Margin="2,0,0,0" Click="LibraryNav_Click"/>
        <Button x:Name="SetupNavButton" Content="PC setup" Style="{StaticResource NavButton}" MinWidth="108" Margin="2,0,0,0" Click="SetupNav_Click"/>
      </StackPanel>
    </Border>

    <!-- PROFILES -->
    <Grid x:Name="ProfilesScreen" Grid.Row="1" Margin="0,8,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="20"/>
        <ColumnDefinition Width="360"/>
      </Grid.ColumnDefinitions>

      <DockPanel Grid.Column="0">
        <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="8"/>
              <ColumnDefinition Width="120"/>
              <ColumnDefinition Width="8"/>
              <ColumnDefinition Width="120"/>
              <ColumnDefinition Width="8"/>
              <ColumnDefinition Width="140"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
              <TextBlock Text="Search" Style="{StaticResource FieldLabel}"/>
              <TextBox x:Name="ProfileSearchBox" Height="36" TextChanged="ProfileSearch_TextChanged"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
              <TextBlock Text="Folder" Style="{StaticResource FieldLabel}"/>
              <ComboBox x:Name="FolderFilterBox" Height="36" SelectionChanged="FolderFilter_SelectionChanged"/>
            </StackPanel>
            <StackPanel Grid.Column="4">
              <TextBlock Text="Tag" Style="{StaticResource FieldLabel}"/>
              <ComboBox x:Name="TagFilterBox" Height="36" SelectionChanged="TagFilter_SelectionChanged"/>
            </StackPanel>
            <StackPanel Grid.Column="6">
              <TextBlock Text="Sort by" Style="{StaticResource FieldLabel}"/>
              <ComboBox x:Name="ProfileSortBox" Height="36" SelectionChanged="ProfileSort_SelectionChanged">
                <ComboBoxItem Content="Last played"/>
                <ComboBoxItem Content="Server name"/>
                <ComboBoxItem Content="Favourites"/>
              </ComboBox>
            </StackPanel>
          </Grid>
          <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
            <Button x:Name="RestorePreviousButton" Content="Restore previous" Style="{StaticResource GhostButton}" Click="RestorePrevious_Click"/>
            <Button Content="Import legacy" Style="{StaticResource TextButton}" Margin="4,0,0,0" Click="ImportLegacy_Click"/>
            <Button Content="Import" Style="{StaticResource TextButton}" Click="ImportProfiles_Click"/>
            <Button Content="Export" Style="{StaticResource TextButton}" Click="ExportProfiles_Click"/>
            <Button Content="Full backup" Style="{StaticResource TextButton}" Click="PortableBackup_Click"/>
          </StackPanel>
        </Grid>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel>
            <Border x:Name="EmptyProfilesPanel" Visibility="Collapsed" Style="{StaticResource Card}" Padding="28" Margin="0,20,0,0">
              <StackPanel HorizontalAlignment="Center" MaxWidth="360">
                <TextBlock Text="No profiles yet" FontSize="17" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                <TextBlock Text="Add your first server on the right — pick a soundpack, ReShade look, and any startup commands, then hit Play." Style="{StaticResource Hint}" TextAlignment="Center" Margin="0,8,0,0"/>
              </StackPanel>
            </Border>

            <ItemsControl x:Name="ProfilesItems">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Style="{StaticResource ProfileCard}" MouseLeftButtonDown="ProfileCard_Select" Cursor="Hand">
                    <Grid>
                      <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                      </Grid.RowDefinitions>

                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="Auto"/>
                          <ColumnDefinition Width="*"/>
                          <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Content="{Binding FavoriteGlyph}" Style="{StaticResource TextButton}" Tag="{Binding}" Click="FavouriteProfile_Click" FontSize="16" Padding="2,0,8,0" VerticalAlignment="Top"/>
                        <StackPanel Grid.Column="1">
                          <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold"/>
                          <TextBlock Text="{Binding Connect}" Style="{StaticResource Hint}" Margin="0,2,0,0"/>
                          <Button Content="Copy connect" Style="{StaticResource TextButton}" Tag="{Binding}" Click="CopyConnect_Click" HorizontalAlignment="Left" Padding="0,2,0,0" FontSize="11"/>
                          <TextBlock Text="{Binding LastPlayedText}" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,4,0,0"/>
                          <TextBlock Foreground="{StaticResource AccentBrush}" FontSize="11" Margin="0,2,0,0">
                            <TextBlock.Style>
                              <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="{Binding FolderLabel}"/>
                                <Style.Triggers>
                                  <DataTrigger Binding="{Binding FolderLabel}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                  </DataTrigger>
                                </Style.Triggers>
                              </Style>
                            </TextBlock.Style>
                          </TextBlock>
                          <TextBlock Text="{Binding TagsLabel}" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Border Grid.Column="2" Style="{StaticResource StatusChip}" VerticalAlignment="Top">
                          <TextBlock Text="{Binding Readiness}" Foreground="{Binding ReadinessColor}" FontSize="11" FontWeight="SemiBold"/>
                        </Border>
                      </Grid>

                      <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,12,0,0">
                        <Border Background="{StaticResource SurfaceRaisedBrush}" CornerRadius="6" Padding="8,4" Margin="0,0,6,0">
                          <TextBlock FontSize="11.5">
                            <Run Text="Sound " Foreground="{StaticResource MutedBrush}"/>
                            <Run Text="{Binding Soundpack}" FontWeight="SemiBold"/>
                          </TextBlock>
                        </Border>
                        <Border Background="{StaticResource SurfaceRaisedBrush}" CornerRadius="6" Padding="8,4">
                          <TextBlock FontSize="11.5">
                            <Run Text="Look " Foreground="{StaticResource MutedBrush}"/>
                            <Run Text="{Binding Reshade}" FontWeight="SemiBold"/>
                          </TextBlock>
                        </Border>
                        <TextBlock Text="{Binding CommandCountText}" Foreground="{StaticResource MutedBrush}" FontSize="11" VerticalAlignment="Center" Margin="10,0,0,0"/>
                      </StackPanel>

                      <Grid Grid.Row="2" Margin="0,12,0,0">
                        <StackPanel Orientation="Horizontal">
                          <Button Content="Play" Style="{StaticResource PrimaryButton}" Tag="{Binding}" Click="PlayProfile_Click" Padding="20,8"/>
                          <Button Content="Edit" Style="{StaticResource GhostButton}" Tag="{Binding}" Click="EditProfile_Click" Margin="8,0,0,0"/>
                          <Button Content="More" Style="{StaticResource TextButton}" Tag="{Binding}" Click="ProfileMore_Click" Margin="4,0,0,0"/>
                        </StackPanel>
                      </Grid>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </ScrollViewer>
      </DockPanel>

      <!-- Profile form -->
      <Border Grid.Column="2" Style="{StaticResource Card}" BorderBrush="#3A3430" Padding="18">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel>
            <TextBlock x:Name="ProfileFormEyebrow" Text="New profile" Style="{StaticResource SectionLabel}"/>
            <TextBlock x:Name="ProfileFormTitle" Text="Add a server" FontSize="18" FontWeight="SemiBold" Margin="0,4,0,0"/>
            <TextBlock Text="Everything here applies when you hit Play." Style="{StaticResource Hint}" Margin="0,4,0,0"/>

            <TextBlock Text="Name" Style="{StaticResource FieldLabel}" Margin="0,16,0,0"/>
            <TextBox x:Name="ProfileNameBox" Height="36"/>

            <Grid Margin="0,12,0,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <StackPanel>
                <TextBlock Text="Folder" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="ProfileFolderBox" Height="36"/>
              </StackPanel>
              <StackPanel Grid.Column="2">
                <TextBlock Text="Tags" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="ProfileTagsBox" Height="36"/>
              </StackPanel>
            </Grid>

            <TextBlock Text="Connect code, link, or IP" Style="{StaticResource FieldLabel}" Margin="0,12,0,0"/>
            <TextBox x:Name="ProfileConnectBox" Height="36"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
              <Button x:Name="DetectServerButton" Content="Detect from FiveM" Style="{StaticResource TextButton}" Click="DetectServer_Click"/>
              <Button x:Name="TestConnectionButton" Content="Test" Style="{StaticResource GhostButton}" Margin="6,0,0,0" Padding="12,6" Click="TestConnection_Click"/>
            </StackPanel>

            <Grid Margin="0,14,0,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <StackPanel>
                <TextBlock Text="Soundpack" Style="{StaticResource FieldLabel}"/>
                <ComboBox x:Name="SoundpackBox" Height="36"/>
              </StackPanel>
              <StackPanel Grid.Column="2">
                <TextBlock Text="ReShade look" Style="{StaticResource FieldLabel}"/>
                <ComboBox x:Name="ReShadeBox" Height="36"/>
              </StackPanel>
            </Grid>

            <TextBlock Text="Startup commands" Style="{StaticResource FieldLabel}" Margin="0,14,0,0"/>
            <Border Background="{StaticResource SurfaceRaisedBrush}" BorderBrush="{StaticResource EdgeBrush}" BorderThickness="1" CornerRadius="10" Padding="4">
              <ListBox x:Name="CommandList" Height="168" SelectionMode="Extended" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ItemContainerStyle="{StaticResource CommandItem}" SelectionChanged="CommandList_SelectionChanged">
                <ListBox.ItemTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding Label}" TextWrapping="Wrap" FontSize="12"/>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </Border>
            <TextBlock x:Name="CommandSummaryText" Text="Click to select. Ctrl+click for multiple." Style="{StaticResource Hint}" Margin="0,6,0,0"/>

            <StackPanel x:Name="MouseScalePanel" Visibility="Collapsed" Margin="0,10,0,0">
              <TextBlock Text="On-foot mouse scale" Style="{StaticResource FieldLabel}"/>
              <TextBox x:Name="MouseScaleBox" Height="36" TextChanged="CommandValue_TextChanged"/>
            </StackPanel>
            <StackPanel x:Name="FovPanel" Visibility="Collapsed" Margin="0,10,0,0">
              <TextBlock Text="First-person FOV" Style="{StaticResource FieldLabel}"/>
              <TextBox x:Name="FovBox" Height="36" TextChanged="CommandValue_TextChanged"/>
              <TextBlock Text="Only works on servers that allow it." Style="{StaticResource Hint}"/>
            </StackPanel>

            <Border Background="{StaticResource SurfaceRaisedBrush}" CornerRadius="10" Padding="12" Margin="0,12,0,0">
              <StackPanel>
                <TextBlock Text="Custom command" Style="{StaticResource FieldLabel}" Margin="0"/>
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>
                  <TextBox x:Name="CustomNameBox" Height="36"/>
                  <TextBox x:Name="CustomValueBox" Grid.Column="2" Height="36"/>
                </Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                  <Button Content="Remove selected" Style="{StaticResource TextButton}" Click="RemoveCustomCommand_Click"/>
                  <Button Content="Add" Style="{StaticResource GhostButton}" Margin="6,0,0,0" Padding="12,6" Click="AddCustomCommand_Click"/>
                </StackPanel>
              </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
              <Button x:Name="CancelEditButton" Content="Cancel" Style="{StaticResource TextButton}" Visibility="Collapsed" Click="CancelEdit_Click"/>
              <Button x:Name="SaveProfileButton" Content="Save profile" Style="{StaticResource PrimaryButton}" Margin="8,0,0,0" Click="SaveProfile_Click"/>
            </StackPanel>
          </StackPanel>
        </ScrollViewer>
      </Border>
    </Grid>

    <local:LibrarySection x:Name="LibrarySectionView" Grid.Row="1" Margin="0,8,0,0" Visibility="Collapsed"/>

    <!-- PC SETUP -->
    <Grid x:Name="SetupScreen" Grid.Row="1" Margin="0,8,0,0" Visibility="Collapsed">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>

      <Border Style="{StaticResource Card}" Padding="18" Margin="0,0,0,14">
        <StackPanel>
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <StackPanel>
            <TextBlock Text="Guided PC setup" FontSize="18" FontWeight="SemiBold"/>
            <TextBlock Text="Pick what you want installed or changed. Nothing runs until you review and start." Style="{StaticResource Hint}" Margin="0,4,0,0"/>
          </StackPanel>
          <TextBlock x:Name="SetupCountText" Grid.Column="1" Text="0 tasks selected" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" VerticalAlignment="Center"/>
        </Grid>
        <Grid Margin="0,14,0,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>
          <Border Grid.Column="0" Background="{StaticResource SurfaceRaisedBrush}" CornerRadius="8" Padding="12,10">
            <StackPanel>
              <TextBlock Text="CPU" Style="{StaticResource FieldLabel}" Margin="0"/>
              <TextBlock x:Name="CpuText" Text="Detecting…" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
            </StackPanel>
          </Border>
          <Border Grid.Column="2" Background="{StaticResource SurfaceRaisedBrush}" CornerRadius="8" Padding="12,10">
            <StackPanel>
              <TextBlock Text="GPU" Style="{StaticResource FieldLabel}" Margin="0"/>
              <TextBlock x:Name="GpuText" Text="Detecting…" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
            </StackPanel>
          </Border>
          <Border Grid.Column="4" Background="{StaticResource SurfaceRaisedBrush}" CornerRadius="8" Padding="12,10">
            <StackPanel>
              <TextBlock Text="Windows" Style="{StaticResource FieldLabel}" Margin="0"/>
              <TextBlock x:Name="WindowsText" Text="Detecting…" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
            </StackPanel>
          </Border>
        </Grid>
        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
          <Button Content="Recommended" Style="{StaticResource PrimaryButton}" Padding="14,8" Click="RecommendedSetup_Click"/>
          <Button Content="Clear all" Style="{StaticResource TextButton}" Margin="8,0,0,0" Click="ClearSetup_Click"/>
        </StackPanel>
        </StackPanel>
      </Border>

      <Grid Grid.Row="1">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="16"/>
          <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel>
            <Border Style="{StaticResource Card}" Margin="0,0,0,12">
              <StackPanel>
                <TextBlock Text="Apps" FontSize="15" FontWeight="SemiBold"/>
                <TextBlock Text="Installed via winget — already-present apps are skipped." Style="{StaticResource Hint}" Margin="0,3,0,0"/>
                <ItemsControl x:Name="SetupAppsItems" Margin="0,12,0,0">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border BorderBrush="{StaticResource EdgeBrush}" BorderThickness="0,0,0,1" Padding="0,10">
                        <Grid>
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                          </Grid.ColumnDefinitions>
                          <StackPanel>
                            <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Description}" Style="{StaticResource Hint}"/>
                          </StackPanel>
                          <CheckBox Grid.Column="1" IsChecked="{Binding IsSelected, Mode=TwoWay}" Checked="SetupChoice_Changed" Unchecked="SetupChoice_Changed"/>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,0,0,12">
              <StackPanel>
                <TextBlock Text="Drivers and input" FontSize="15" FontWeight="SemiBold"/>
                <Grid Margin="0,12,0,0">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <StackPanel>
                    <TextBlock Text="Local driver packages" FontWeight="SemiBold"/>
                    <TextBlock x:Name="DriversDetailText" Text="No packages detected." Style="{StaticResource Hint}"/>
                    <Button Content="Open Drivers folder" Style="{StaticResource TextButton}" HorizontalAlignment="Left" Margin="0,4,0,0" Click="OpenDrivers_Click"/>
                  </StackPanel>
                  <CheckBox x:Name="DriversCheck" Grid.Column="1" Checked="SetupChoice_Changed" Unchecked="SetupChoice_Changed"/>
                </Grid>
                <Border Height="1" Background="{StaticResource EdgeBrush}" Margin="0,12"/>
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <StackPanel>
                    <TextBlock Text="Disable mouse acceleration" FontWeight="SemiBold"/>
                    <TextBlock Text="Turns off Enhance Pointer Precision." Style="{StaticResource Hint}"/>
                  </StackPanel>
                  <CheckBox x:Name="MouseCheck" Grid.Column="1" Checked="SetupChoice_Changed" Unchecked="SetupChoice_Changed"/>
                </Grid>
              </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,0,0,12">
              <StackPanel>
                <TextBlock Text="FiveM and graphics" FontSize="15" FontWeight="SemiBold"/>
                <Grid Margin="0,12,0,0">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <StackPanel>
                    <TextBlock Text="FiveM installer" FontWeight="SemiBold"/>
                    <TextBlock Text="Download, verify, and open the official installer." Style="{StaticResource Hint}"/>
                  </StackPanel>
                  <CheckBox x:Name="FiveMCheck" Grid.Column="1" IsChecked="True" Checked="SetupChoice_Changed" Unchecked="SetupChoice_Changed"/>
                </Grid>
                <Border Height="1" Background="{StaticResource EdgeBrush}" Margin="0,12"/>
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <StackPanel>
                    <TextBlock Text="ReShade for FiveM" FontWeight="SemiBold"/>
                    <TextBlock Text="Verified installer from the official site." Style="{StaticResource Hint}"/>
                  </StackPanel>
                  <CheckBox x:Name="ReShadeCheck" Grid.Column="1" IsChecked="True" Checked="SetupChoice_Changed" Unchecked="SetupChoice_Changed"/>
                </Grid>
              </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
              <StackPanel>
                <TextBlock Text="Backup and finish" FontSize="15" FontWeight="SemiBold"/>
                <Grid Margin="0,12,0,0">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <StackPanel>
                    <TextBlock Text="Restore portable backup" FontWeight="SemiBold"/>
                    <TextBlock x:Name="BackupDetailText" Text="No backup available." Style="{StaticResource Hint}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                      <Button Content="Back up now" Style="{StaticResource TextButton}" Click="BackupNow_Click"/>
                      <Button Content="Open folder" Style="{StaticResource TextButton}" Margin="6,0,0,0" Click="OpenBackup_Click"/>
                    </StackPanel>
                  </StackPanel>
                  <CheckBox x:Name="RestoreCheck" Grid.Column="1" Checked="SetupChoice_Changed" Unchecked="SetupChoice_Changed"/>
                </Grid>
                <Border Height="1" Background="{StaticResource EdgeBrush}" Margin="0,12"/>
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <StackPanel>
                    <TextBlock Text="Open apps when done" FontWeight="SemiBold"/>
                    <TextBlock Text="Launch apps that support it after setup." Style="{StaticResource Hint}"/>
                  </StackPanel>
                  <CheckBox x:Name="LaunchCheck" Grid.Column="1" Checked="SetupChoice_Changed" Unchecked="SetupChoice_Changed"/>
                </Grid>
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>

        <Border Grid.Column="2" Style="{StaticResource Card}" Padding="16">
          <DockPanel>
            <StackPanel DockPanel.Dock="Bottom" Margin="0,14,0,0">
              <Button Content="Start setup" Style="{StaticResource PrimaryButton}" Click="StartSetup_Click"/>
              <TextBlock Text="Admin permission is only asked when you start." Style="{StaticResource Hint}" TextAlignment="Center" Margin="0,8,0,0"/>
              <Button Content="Edit app list" Style="{StaticResource TextButton}" Margin="0,6,0,0" Click="EditConfig_Click"/>
            </StackPanel>
            <StackPanel>
              <TextBlock Text="Summary" FontSize="16" FontWeight="SemiBold"/>
              <TextBlock x:Name="SetupSummaryText" Text="Nothing selected yet." FontSize="12" TextWrapping="Wrap" LineHeight="22" Margin="0,12,0,0"/>
              <Border Background="{StaticResource AmberSoftBrush}" BorderBrush="#4A3E20" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,16,0,0">
                <TextBlock Text="Driver installers may need input and a restart." Foreground="{StaticResource AmberBrush}" FontSize="11.5" TextWrapping="Wrap"/>
              </Border>
            </StackPanel>
          </DockPanel>
        </Border>
      </Grid>
    </Grid>

    <!-- PROGRESS -->
    <Grid x:Name="ProgressScreen" Grid.Row="1" Margin="0,8,0,0" Visibility="Collapsed">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <Border Style="{StaticResource Card}" Padding="18">
        <StackPanel>
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <StackPanel>
            <TextBlock x:Name="ProgressTitleText" Text="Setting up your PC" FontSize="18" FontWeight="SemiBold"/>
            <TextBlock x:Name="ProgressCurrentText" Text="Preparing tasks…" Style="{StaticResource Hint}" Margin="0,4,0,0"/>
          </StackPanel>
          <Border Grid.Column="1" Style="{StaticResource StatusChip}" VerticalAlignment="Top">
            <TextBlock x:Name="ProgressStateText" Text="In progress" FontSize="11" FontWeight="SemiBold"/>
          </Border>
        </Grid>
        <Grid Margin="0,14,0,0">
          <ProgressBar x:Name="OverallProgressBar" Height="6" Minimum="0" Maximum="100" Value="0"/>
          <TextBlock x:Name="ProgressPercentText" Text="0%" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,-2,0,0"/>
        </Grid>
        </StackPanel>
      </Border>

      <Border x:Name="CompletionBanner" Grid.Row="1" Background="{StaticResource GreenSoftBrush}" BorderBrush="#2A4A38" BorderThickness="1" CornerRadius="10" Padding="12,10" Margin="0,12,0,0" Visibility="Collapsed">
        <TextBlock x:Name="CompletionText" Text="Setup completed." Foreground="{StaticResource GreenBrush}" FontWeight="SemiBold"/>
      </Border>

      <Grid Grid.Row="2" Margin="0,12,0,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="14"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Border Style="{StaticResource Card}">
          <DockPanel>
            <TextBlock Text="Tasks" Style="{StaticResource SectionLabel}" DockPanel.Dock="Top" Margin="0,0,0,10"/>
            <ScrollViewer VerticalScrollBarVisibility="Auto">
              <ItemsControl x:Name="ProgressTasksItems">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Background="{StaticResource SurfaceRaisedBrush}" BorderBrush="{Binding Color}" BorderThickness="0,0,0,2" CornerRadius="8" Padding="12" Margin="0,0,0,8">
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*"/>
                          <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                          <TextBlock Text="{Binding Label}" FontWeight="SemiBold"/>
                          <TextBlock Text="{Binding Detail}" Style="{StaticResource Hint}" Margin="0,2,0,0"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="{Binding State}" Foreground="{Binding Color}" FontSize="11" FontWeight="SemiBold" Margin="12,0,0,0" VerticalAlignment="Center"/>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </DockPanel>
        </Border>
        <Border Grid.Column="2" Style="{StaticResource Card}" Padding="0">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border Background="{StaticResource SurfaceRaisedBrush}" Padding="12,10" CornerRadius="11,11,0,0">
              <TextBlock Text="Output" Style="{StaticResource SectionLabel}"/>
            </Border>
            <TextBox x:Name="ProgressLogBox" Grid.Row="1" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Background="#0E0E10" BorderThickness="0" FontFamily="Cascadia Mono, Consolas" FontSize="11.5" Padding="12"/>
          </Grid>
        </Border>
      </Grid>

      <Grid Grid.Row="3" Margin="0,14,0,0">
        <TextBlock Text="Keep the PC on while setup runs." Foreground="{StaticResource MutedBrush}" FontSize="11.5" VerticalAlignment="Center"/>
        <Button x:Name="ProgressBackButton" Content="Back to setup" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Right" IsEnabled="False" Click="ProgressBack_Click"/>
      </Grid>
    </Grid>

    <!-- Status bar -->
    <Border Grid.Row="2" Margin="0,14,0,0" Padding="2,0">
      <Grid>
        <TextBlock x:Name="ProfileStatusText" Text="Ready" Style="{StaticResource Hint}" Visibility="Visible"/>
        <TextBlock x:Name="SetupStatusText" Text="Choose the changes you want, then start setup." Style="{StaticResource Hint}" Visibility="Collapsed"/>
      </Grid>
    </Border>

    <StackPanel x:Name="ToastPanel" Grid.Row="0" Grid.RowSpan="3" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0,0,4,52" IsHitTestVisible="False"/>
  </Grid>
</Window>
