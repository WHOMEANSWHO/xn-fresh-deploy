<Window x:Class="XnFreshDeploy.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="360" Height="220" WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" WindowStartupLocation="CenterScreen" ShowInTaskbar="False"
        Topmost="True" FontFamily="Segoe UI">
  <Border Background="#121214" BorderBrush="#34343A" BorderThickness="1" CornerRadius="14" Padding="28">
    <StackPanel VerticalAlignment="Center">
      <TextBlock Text="Xn Fresh Deploy" FontSize="22" FontWeight="SemiBold" Foreground="#ECECEF"/>
      <TextBlock Text="FiveM profiles and PC setup" FontSize="12" Foreground="#8E8E96" Margin="0,6,0,18"/>
      <ProgressBar IsIndeterminate="True" Height="4" Foreground="#D4845A" Background="#222226" BorderThickness="0"/>
      <TextBlock Text="Starting…" FontSize="11" Foreground="#8E8E96" Margin="0,10,0,0"/>
    </StackPanel>
  </Border>
</Window>
