<Window x:Class="XnFreshDeploy.FirstRunWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Welcome" Width="520" Height="360" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" Background="{StaticResource BackgroundBrush}"
        FontFamily="Segoe UI" Icon="pack://application:,,,/app.ico">
  <Border Style="{StaticResource Card}" Margin="18">
    <DockPanel>
      <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
        <Button x:Name="BackButton" Content="Back" Style="{StaticResource TextButton}" Visibility="Collapsed" Click="Back_Click"/>
        <Button x:Name="NextButton" Content="Next" Style="{StaticResource PrimaryButton}" Margin="8,0,0,0" Click="Next_Click"/>
      </StackPanel>

      <StackPanel>
        <TextBlock Text="Welcome to Xn Fresh Deploy" FontSize="20" FontWeight="SemiBold"/>
        <TextBlock Text="Three quick steps to get playing." Style="{StaticResource Hint}" Margin="0,6,0,18"/>

        <Border x:Name="Step1Panel" Background="{StaticResource SurfaceRaisedBrush}" CornerRadius="10" Padding="14" Margin="0,0,0,10">
          <StackPanel>
            <TextBlock Text="1. Add a server" FontWeight="SemiBold"/>
            <TextBlock Text="Use the form on the right with a connect code, cfx.re link, or IP. Detect from FiveM if you already joined once." Style="{StaticResource Hint}" Margin="0,4,0,0"/>
          </StackPanel>
        </Border>
        <Border x:Name="Step2Panel" Background="{StaticResource SurfaceBrush}" CornerRadius="10" Padding="14" Margin="0,0,0,10" Opacity="0.55">
          <StackPanel>
            <TextBlock Text="2. Import a pack" FontWeight="SemiBold"/>
            <TextBlock Text="Open Library and drop soundpack or ReShade folders/ZIPs in. Imports are previewed before anything is copied." Style="{StaticResource Hint}" Margin="0,4,0,0"/>
          </StackPanel>
        </Border>
        <Border x:Name="Step3Panel" Background="{StaticResource SurfaceBrush}" CornerRadius="10" Padding="14" Opacity="0.55">
          <StackPanel>
            <TextBlock Text="3. Hit Play" FontWeight="SemiBold"/>
            <TextBlock Text="Each profile applies its sound, look, and startup commands, then connects. Close FiveM before switching packs." Style="{StaticResource Hint}" Margin="0,4,0,0"/>
          </StackPanel>
        </Border>
      </StackPanel>
    </DockPanel>
  </Border>
</Window>
